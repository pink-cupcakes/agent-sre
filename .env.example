# Agent identity
SERVICE_NAME=agent-sre
DEPLOYMENT_ENV=development

# Datadog — ddtrace sends to the local agent; no API key needed in the app.
# The agent sidecar (ECS/k8s) holds DD_API_KEY and forwards to Datadog's backend.
# DD_AGENT_HOST defaults to localhost; override if the agent runs elsewhere.
DD_AGENT_HOST=localhost
DD_LOGS_INJECTION=true

# Anthropic
ANTHROPIC_API_KEY=your-key-here
LLM_MODEL=claude-sonnet-4-20250514
